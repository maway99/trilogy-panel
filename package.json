{
  "name": "trilogy-panel",
  "version": "1.0.0",
  "description": "Trilogy Nightclub touch panel — Node server (Express + WebSocket) bridging touch UI to grandMA2 and Resolume.",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "client:dev": "npm --prefix client run dev",
    "client:build": "npm --prefix client run build",
    "client:install": "npm --prefix client install"
  },
  "dependencies": {
    "express": "^4.19.2",
    "ws": "^8.16.0"
  }
}
